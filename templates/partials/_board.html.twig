{# Jest fajny efekt animacji przez manipulowanie "gap" w CSS #}
<div x-effect="renderMoves(selectedMove)">
    <div class="scrabble-board">
        <template x-for="row in 15" :key="row">
            <template x-for="col in 15" :key="col">
                <div
                        class="scrabble-cell"
                        :class="tileClass(row - 1, col - 1)"
                        x-html="renderTile(15 - row, col - 1) ?? ''"
                ></div>
            </template>
        </template>
    </div>
</div>
