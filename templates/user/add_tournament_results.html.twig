{% extends 'base.html.twig' %}

{% block title %}Dodaj wyniki turnieju{% endblock %}

{% block body %}
    <section class="section" x-data="addTournamentResultsPage()" x-init="load()">
        <div class="columns" style="margin-top: 32px;">
            <aside class="column is-3">
                {% include 'user/_side_menu.html.twig' with {
                    activeMenuItem: 'add_tournament_results'
                } %}
            </aside>

            <div class="column is-9">
                <article class="message is-danger" x-show="error" x-cloak>
                    <div class="message-body" x-text="error"></div>
                </article>

                <article class="message is-success" x-show="success" x-cloak>
                    <div class="message-body" x-text="success"></div>
                </article>

                <div class="box" x-show="loading" x-cloak>
                    Ladowanie...
                </div>

                <div class="box" x-show="!loading && data" x-cloak>
                    <h1 class="title is-4" x-text="data.title"></h1>
                    <p class="mb-5" x-text="data.description"></p>

                    <div class="field">
                        <label class="label">Organizacja</label>
                        <div class="control">
                            <div class="select is-fullwidth">
                                <select x-model="selectedOrganizationId">
                                    <template x-for="organization in data.organizations" :key="organization.id">
                                        <option x-bind:value="organization.id" x-text="organization.name"></option>
                                    </template>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="field">
                        <label class="label">Pliki z wynikami</label>
                        <div class="control">
                            <input
                                type="file"
                                class="input"
                                accept=".txt,text/plain"
                                x-ref="resultsInput"
                                x-bind:disabled="!selectedOrganizationId || preprocessing"
                                x-on:change="preprocessResultsFile"
                            >
                        </div>
                        <p class="help" x-show="!preprocessing">Wybierz plik HH z wynikami turnieju.</p>
                        <p class="help" x-show="preprocessing" x-cloak>Przetwarzanie pliku...</p>
                    </div>

                    <div class="notification is-light mt-5">
                        <p class="has-text-weight-semibold mb-2">Ostatnie importy</p>
                        <template x-if="data.recentImports.length === 0">
                            <p>Brak importów do wyświetlenia.</p>
                        </template>
                    </div>
                </div>
            </div>
        </div>

        <div
            class="modal"
            x-bind:class="{ 'is-active': previewModalOpen }"
            x-show="previewModalOpen"
            x-cloak
            x-on:click="handlePreviewModalClick"
        >
            <div class="modal-background" data-preview-action="cancel"></div>
            <div x-html="previewHtml"></div>
        </div>
    </section>

    <script>
        function addTournamentResultsPage() {
            return {
                loading: true,
                error: '',
                success: '',
                data: null,
                profile: null,
                selectedOrganizationId: '',
                preprocessing: false,
                importing: false,
                previewHtml: '',
                previewModalOpen: false,
                pendingResultsFile: null,
                pendingOrganizationId: '',
                async load() {
                    this.loading = true;
                    this.error = '';
                    this.success = '';

                    try {
                        const response = await fetch('/api/user/tournament-results/add/data', {
                            method: 'GET',
                            credentials: 'include'
                        });

                        if (!response.ok) {
                            this.error = response.status === 403
                                ? 'Nie masz uprawnień do tej strony.'
                                : 'Nie udalo sie pobrac danych.';
                            return;
                        }

                        const payload = await response.json();
                        this.profile = payload.profile ?? null;
                        this.data = {
                            title: payload.title ?? 'Dodaj wyniki turnieju',
                            description: payload.description ?? '',
                            organizations: payload.organizations ?? [],
                            recentImports: payload.recentImports ?? []
                        };
                        this.selectedOrganizationId = this.data.organizations[0]?.id ?? '';
                    } catch (e) {
                        this.error = 'Blad podczas laczenia z serwerem.';
                    } finally {
                        this.loading = false;
                    }
                },
                async preprocessResultsFile(event) {
                    this.error = '';
                    this.success = '';
                    this.pendingResultsFile = null;
                    this.pendingOrganizationId = '';
                    const file = event.target.files?.[0];
                    if (!file) {
                        return;
                    }

                    if (!this.selectedOrganizationId) {
                        this.error = 'Wybierz organizacje.';
                        event.target.value = '';
                        return;
                    }

                    const formData = new FormData();
                    formData.append('results', file);
                    formData.append('organizationId', this.selectedOrganizationId);
                    this.preprocessing = true;

                    try {
                        const response = await fetch('/api/user/tournament-results/preprocess-club-results', {
                            method: 'POST',
                            body: formData,
                            credentials: 'include'
                        });

                        const text = await response.text();
                        if (!response.ok) {
                            this.error = text || 'Nie udalo sie przetworzyc pliku.';
                            return;
                        }

                        this.pendingResultsFile = file;
                        this.pendingOrganizationId = this.selectedOrganizationId;
                        this.previewHtml = text;
                        this.previewModalOpen = true;
                    } catch (e) {
                        this.error = 'Blad podczas przesylania pliku.';
                    } finally {
                        this.preprocessing = false;
                        event.target.value = '';
                    }
                },
                handlePreviewModalClick(event) {
                    const actionTarget = event.target.closest('[data-preview-action]');
                    const action = actionTarget?.dataset.previewAction;
                    if (action === 'cancel') {
                        this.closePreviewModal();
                    } else if (action === 'confirm') {
                        this.importResultsFile();
                    }
                },
                async importResultsFile() {
                    if (this.importing) {
                        return;
                    }

                    if (!this.pendingResultsFile || !this.pendingOrganizationId) {
                        this.error = 'Brak pliku do importu.';
                        this.closePreviewModal();
                        return;
                    }

                    this.error = '';
                    this.success = '';
                    this.importing = true;

                    const formData = new FormData();
                    formData.append('results', this.pendingResultsFile);
                    formData.append('organizationId', this.pendingOrganizationId);

                    try {
                        const response = await fetch('/api/user/tournament-results/import-club-results', {
                            method: 'POST',
                            body: formData,
                            credentials: 'include'
                        });

                        const text = await response.text();
                        if (!response.ok) {
                            this.closePreviewModal();
                            this.error = text || 'Nie udalo sie zaimportowac turnieju.';
                            return;
                        }

                        let payload = {};
                        try {
                            payload = text ? JSON.parse(text) : {};
                        } catch (e) {
                            payload = {};
                        }

                        this.closePreviewModal();
                        await this.load();
                        this.success = payload.message ?? 'Turniej zostal zaimportowany.';
                    } catch (e) {
                        this.closePreviewModal();
                        this.error = 'Blad podczas importu turnieju.';
                    } finally {
                        this.importing = false;
                    }
                },
                closePreviewModal() {
                    this.previewModalOpen = false;
                    this.previewHtml = '';
                    this.pendingResultsFile = null;
                    this.pendingOrganizationId = '';
                }
            };
        }
    </script>
{% endblock %}
