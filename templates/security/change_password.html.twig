{% extends 'base.html.twig' %}

{% block title %}Zmień hasło{% endblock %}

{% block body %}
    <section class="section">
        <div class="columns is-centered">
            <div class="column is-12-mobile is-8-tablet is-5-desktop">
                <h1 class="title is-3 has-text-centered">Zmień hasło</h1>
                <p class="subtitle is-6 has-text-centered">Przy pierwszym logowaniu musisz ustawić nowe hasło.</p>

                {% for message in app.flashes('success') %}
                    <article class="message is-success">
                        <div class="message-body">
                            {{ message }}
                        </div>
                    </article>
                {% endfor %}

                {% if errors is not empty %}
                    <article class="message is-danger">
                        <div class="message-body">
                            {% for error in errors %}
                                <div>{{ error }}</div>
                            {% endfor %}
                        </div>
                    </article>
                {% endif %}

                <form method="post" action="{{ path('app_user_change_password') }}" class="box" id="change-password-form" novalidate>
                    <div class="field">
                        <label class="label" for="input-password">Haslo</label>
                        <div class="control">
                            <input
                                id="input-password"
                                class="input"
                                type="password"
                                name="password"
                                autocomplete="new-password"
                                minlength="8"
                                required
                                autofocus
                            >
                        </div>
                        <p class="help">Minimum 8 znakow.</p>
                    </div>

                    <div class="field">
                        <label class="label" for="input-password-confirmation">Potwierdz haslo</label>
                        <div class="control">
                            <input
                                id="input-password-confirmation"
                                class="input"
                                type="password"
                                name="password_confirmation"
                                autocomplete="new-password"
                                minlength="8"
                                required
                            >
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('change_password') }}">

                    <div class="field">
                        <div class="control">
                            <button class="button is-primary is-fullwidth" type="submit">Zmień hasło</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('change-password-form');
            const passwordInput = document.getElementById('input-password');
            const confirmationInput = document.getElementById('input-password-confirmation');

            if (!form || !passwordInput || !confirmationInput) {
                return;
            }

            const validate = () => {
                if (passwordInput.value.length > 0 && passwordInput.value.length < 8) {
                    passwordInput.setCustomValidity('Haslo musi miec co najmniej 8 znakow.');
                } else {
                    passwordInput.setCustomValidity('');
                }

                if (confirmationInput.value !== passwordInput.value) {
                    confirmationInput.setCustomValidity('Haslo i potwierdzenie hasla musza byc takie same.');
                } else {
                    confirmationInput.setCustomValidity('');
                }
            };

            passwordInput.addEventListener('input', validate);
            confirmationInput.addEventListener('input', validate);

            form.addEventListener('submit', (event) => {
                validate();

                if (!form.checkValidity()) {
                    event.preventDefault();
                    form.reportValidity();
                }
            });
        });
    </script>
{% endblock %}
