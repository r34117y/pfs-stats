{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'avg_points_per_game' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/static/stats_avg_points_per_game.css') }}">
{% endblock %}

{% block stats_content %}
    <div x-data="avgPointsPerGameData()" x-init="fetchRows()">
        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            <div class="control mb-5">
                <input class="input" type="search" placeholder="Filtruj" @input="setSearch($event.target.value)">
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div style="overflow-x: auto;">
                <table class="table is-bordered is-hoverable is-fullwidth avg-points-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')" style="cursor: pointer;">#</th>
                        <th @click="sort('playerName')" style="cursor: pointer;">Zawodnik</th>
                        <th class="has-text-centered" @click="sort('averagePoints')" style="cursor: pointer;">Średnia</th>
                        <th class="has-text-centered" @click="sort('last24MonthsAveragePoints')" style="cursor: pointer;">Ost 24 mies.</th>
                        <th class="has-text-centered" @click="sort('last12MonthsAveragePoints')" style="cursor: pointer;">Ost 12 mies.</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="row.playerId">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td>
                                <div class="avg-points-player-cell">
                                    <a :href="$store.playerLinks.profile(row.playerId)" x-text="row.playerName"></a>
                                    <div class="avg-points-player-mobile-meta">
                                        <span x-text="formatFloat(row.averagePoints)"></span>
                                        <span x-text="formatFloat(row.last24MonthsAveragePoints)"></span>
                                        <span x-text="formatFloat(row.last12MonthsAveragePoints)"></span>
                                    </div>
                                </div>
                            </td>
                            <td class="has-text-centered" x-text="formatFloat(row.averagePoints)"></td>
                            <td class="has-text-centered" x-text="formatFloat(row.last24MonthsAveragePoints)"></td>
                            <td class="has-text-centered" x-text="formatFloat(row.last12MonthsAveragePoints)"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function avgPointsPerGameData() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                sortCol: 'averagePoints',
                sortAsc: true,
                async fetchRows() {
                    try {
                        let response = await fetch('/api/stats/avg-points-per-game');
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać średniej punktów');
                        }

                        let data = await response.json();
                        this.rows = data.rows;
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.rows.sort((a, b) => {
                        if (a[this.sortCol] < b[this.sortCol]) return this.sortAsc ? 1 : -1;
                        if (a[this.sortCol] > b[this.sortCol]) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                nextPage() {
                    if((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if(this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.playerName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if(this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    } else {
                        return [];
                    }
                },
                formatFloat(value) {
                    return Number(value).toFixed(2);
                }
            };
        }
    </script>
{% endblock %}
