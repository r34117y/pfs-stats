{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'avg_opponents_points' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .avg-opponents-player-cell {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }

        .avg-opponents-player-mobile-meta {
            display: none;
            font-size: 0.8rem;
            color: #7a7a7a;
            line-height: 1.2;
        }

        @media screen and (max-width: 768px) {
            .avg-opponents-table th:nth-child(n+3),
            .avg-opponents-table td:nth-child(n+3) {
                display: none;
            }

            .avg-opponents-player-mobile-meta {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 0.25rem;
                padding-top: 0.35rem;
                border-top: 1px solid #e5e5e5;
            }

            .avg-opponents-player-mobile-meta > span {
                text-align: center;
            }

            .avg-opponents-player-mobile-meta > span + span {
                border-left: 1px solid #e5e5e5;
            }
        }
    </style>
{% endblock %}

{% block stats_content %}
    <div x-data="avgOpponentsPointsData()" x-init="fetchRows()">
        <h1 class="title is-3">Średnia punktów przeciwników</h1>

        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            <div class="control mb-5">
                <input class="input" type="search" placeholder="Filtruj" @input="setSearch($event.target.value)">
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div style="overflow-x: auto;">
                <table class="table is-bordered is-hoverable is-fullwidth avg-opponents-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')" style="cursor: pointer;">#</th>
                        <th @click="sort('playerName')" style="cursor: pointer;">Zawodnik</th>
                        <th class="has-text-centered" @click="sort('averageOpponentPoints')" style="cursor: pointer;">Punktów</th>
                        <th class="has-text-centered" @click="sort('last24MonthsAverageOpponentPoints')" style="cursor: pointer;">Ost 24 mies.</th>
                        <th class="has-text-centered" @click="sort('last12MonthsAverageOpponentPoints')" style="cursor: pointer;">Ost 12 mies.</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="row.playerId">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td>
                                <div class="avg-opponents-player-cell">
                                    <a :href="`/players/${row.playerId}`" x-text="row.playerName"></a>
                                    <div class="avg-opponents-player-mobile-meta">
                                        <span x-text="formatFloat(row.averageOpponentPoints)"></span>
                                        <span x-text="formatFloat(row.last24MonthsAverageOpponentPoints)"></span>
                                        <span x-text="formatFloat(row.last12MonthsAverageOpponentPoints)"></span>
                                    </div>
                                </div>
                            </td>
                            <td class="has-text-centered" x-text="formatFloat(row.averageOpponentPoints)"></td>
                            <td class="has-text-centered" x-text="formatFloat(row.last24MonthsAverageOpponentPoints)"></td>
                            <td class="has-text-centered" x-text="formatFloat(row.last12MonthsAverageOpponentPoints)"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function avgOpponentsPointsData() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                sortCol: 'averageOpponentPoints',
                sortAsc: true,
                async fetchRows() {
                    try {
                        let response = await fetch('/api/stats/avg-opponents-points');
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać średniej punktów przeciwników');
                        }

                        let data = await response.json();
                        this.rows = data.rows;
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.rows.sort((a, b) => {
                        if (a[this.sortCol] < b[this.sortCol]) return this.sortAsc ? 1 : -1;
                        if (a[this.sortCol] > b[this.sortCol]) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                nextPage() {
                    if((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if(this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.playerName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if(this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    } else {
                        return [];
                    }
                },
                formatFloat(value) {
                    return Number(value).toFixed(2);
                }
            };
        }
    </script>
{% endblock %}
