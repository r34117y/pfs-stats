{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/static/game_details.css') }}">
{% endblock %}

{% block body %}
    <div x-data="annotatedGameDetails('{{ gameId|e('js') }}')" x-init="fetchDetails()" style="margin-top: 2rem;">
        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <div x-show="!loading" class="box">
            <template x-if="errorMessage !== ''">
                <article class="message is-danger">
                    <div class="message-body" x-text="errorMessage"></div>
                </article>
            </template>

            <template x-if="errorMessage === '' && details !== null">
                <div>
                    <div class="is-flex is-align-items-center" style="gap: 0.75rem;">
                        <h1 class="title is-4 mb-0">
                            <span x-text="details.player1Name"></span>
                            <span> vs </span>
                            <span x-text="details.player2Name"></span>
                        </h1>
                        <a href="/games" class="button is-light" style="margin-left: auto;">Powrót do listy</a>
                    </div>
                    <p class="subtitle is-6 mb-4">
                        <a :href="`/tournaments/${details.tournamentId}`" x-text="`Turniej: ${details.tournamentName}`"></a>
                    </p>
                    <div class="buttons mb-3">
                        <button class="button" @click="goStart" :disabled="events.length === 0 || selectedMoveIndex === null">|&lt;</button>
                        <button class="button" @click="goPrev" :disabled="events.length === 0 || selectedMoveIndex === null">&lt;</button>
                        <button class="button" @click="goNext" :disabled="events.length === 0 || selectedMoveIndex === events.length - 1">&gt;</button>
                        <button class="button" @click="goEnd" :disabled="events.length === 0 || selectedMoveIndex === events.length - 1">&gt;|</button>
                        <button class="button is-light" @click="selectedMoveIndex = null">Wyczyść planszę</button>
                    </div>

                    <div class="game-layout">
                        <div>
                            {% include 'static/_partials/_board.html.twig' %}
                        </div>

                        <div>
                            <div class="moves-list">
                                <template x-if="events.length === 0">
                                    <p class="has-text-grey">Brak ruchów do wyświetlenia.</p>
                                </template>

                                <template x-if="events.length > 0">
                                    <table class="moves-table">
                                        <thead>
                                            <tr>
                                                <th class="is-numeric">#</th>
                                                <th>Zawodnik</th>
                                                <th>Stojak</th>
                                                <th>Ruch</th>
                                                <th class="is-centered">Pole</th>
                                                <th class="is-numeric">Punkty</th>
                                                <th class="is-numeric">Razem</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <template x-for="(ev, index) in events" :key="ev['@id'] ?? `e-${index}`">
                                                <tr
                                                    :class="{'is-active': selectedMoveIndex === index}"
                                                    @click="selectedMoveIndex = index"
                                                >
                                                    <td class="is-numeric" x-text="`${index + 1}.`"></td>
                                                    <td x-text="playerInitialsForEvent(ev)"></td>
                                                    <td x-text="ev.rack ?? '-'"></td>
                                                    <td x-text="eventLabel(ev)"></td>
                                                    <td class="is-centered" x-text="eventField(ev)"></td>
                                                    <td class="is-numeric" x-text="formatScore(ev.score)"></td>
                                                    <td class="is-numeric" x-text="ev.totalScore ?? 0"></td>
                                                </tr>
                                            </template>
                                        </tbody>
                                    </table>
                                </template>
                            </div>
                        </div>
                    </div>

                    <details class="mt-4">
                        <summary class="is-clickable">Pokaż GCG</summary>
                        <pre style="white-space: pre-wrap; word-break: break-word; margin-top: 0.75rem;"><code x-text="details.data"></code></pre>
                    </details>
                </div>
            </template>
        </div>
    </div>

    <script>
        function annotatedGameDetails(gameId) {
            const SIZE = 15;
            const emptyBoard = () => Array.from({length: SIZE}, () => Array.from({length: SIZE}, () => null));

            const bonusMap = {
                '0,0': 'tw', '0,7': 'tw', '0,14': 'tw', '7,0': 'tw', '7,14': 'tw', '14,0': 'tw', '14,7': 'tw', '14,14': 'tw',
                '1,1': 'dw', '2,2': 'dw', '3,3': 'dw', '4,4': 'dw', '10,10': 'dw', '11,11': 'dw', '12,12': 'dw', '13,13': 'dw',
                '1,13': 'dw', '2,12': 'dw', '3,11': 'dw', '4,10': 'dw', '10,4': 'dw', '11,3': 'dw', '12,2': 'dw', '13,1': 'dw',
                '0,3': 'dl', '0,11': 'dl', '2,6': 'dl', '2,8': 'dl', '3,0': 'dl', '3,7': 'dl', '3,14': 'dl',
                '6,2': 'dl', '6,6': 'dl', '6,8': 'dl', '6,12': 'dl', '7,11': 'dl', '8,2': 'dl', '8,6': 'dl', '8,8': 'dl', '8,12': 'dl',
                '11,0': 'dl', '11,7': 'dl', '11,14': 'dl', '12,6': 'dl', '12,8': 'dl', '14,3': 'dl', '14,11': 'dl',
                '5,5': 'tl', '5,9': 'tl', '9,5': 'tl', '9,9': 'tl', '1,5': 'tl', '1,9': 'tl', '13,5': 'tl', '13,9': 'tl',
                '5,1': 'tl', '5,13': 'tl', '9,1': 'tl', '9,13': 'tl',
            };

            const fieldToCoords = (field) => {
                const letterFirst = /^[A-Z]/i.test(field);

                if (letterFirst) {
                    const col = field.charCodeAt(0) - 'A'.charCodeAt(0);
                    const row = parseInt(field.slice(1), 10) - 1;
                    return {row, col, vertical: true};
                }

                const row = parseInt(field.slice(0, -1), 10) - 1;
                const col = field.slice(-1).toUpperCase().charCodeAt(0) - 'A'.charCodeAt(0);
                return {row, col, vertical: false};
            };

            return {
                gameId,
                details: null,
                loading: true,
                errorMessage: '',
                board: emptyBoard(),
                selectedMoveIndex: null,

                get events() {
                    return this.details?.parsedGcg?.events ?? [];
                },

                get parsedPlayers() {
                    return this.details?.parsedGcg?.players ?? [];
                },

                tileClass(row, col) {
                    if (row === 7 && col === 7) {
                        return 'center';
                    }

                    return bonusMap[`${row},${col}`] ?? '';
                },

                renderTile(x, y) {
                    const tile = this.board[x][y];
                    if (!tile) {
                        return '';
                    }

                    return `<div class="scrabble-tile"><span>${tile.letter}</span></div>`;
                },

                renderBoardUntil(selectedMoveIndex) {
                    this.board = emptyBoard();

                    if (selectedMoveIndex === null) {
                        return;
                    }

                    const events = this.events;
                    for (let i = 0; i <= selectedMoveIndex && i < events.length; i++) {
                        const event = events[i];
                        const previousEvent = i > 0 ? events[i - 1] : null;

                        if (event.type === 'p') {
                            this.placeMove(event);
                        } else if (event.type === 'w') {
                            this.removePreviousMove(previousEvent);
                        }
                    }
                },

                placeMove(move) {
                    const startField = move.startField;
                    const words = move.words ?? [];
                    const word = words.length > 0 ? words[0] : null;

                    if (!startField || !word) {
                        return;
                    }

                    const {row, col, vertical} = fieldToCoords(startField);

                    for (let i = 0; i < word.length; i++) {
                        const rune = word[i];
                        if (rune === '.') {
                            continue;
                        }

                        const r = vertical ? row + i : row;
                        const c = vertical ? col : col + i;

                        if (r < 0 || r >= SIZE || c < 0 || c >= SIZE) {
                            continue;
                        }

                        this.board[r][c] = {letter: rune};
                    }
                },

                removePreviousMove(previousEvent) {
                    if (!previousEvent || previousEvent.type !== 'p') {
                        return;
                    }

                    const startField = previousEvent.startField;
                    const words = previousEvent.words ?? [];
                    const word = words.length > 0 ? words[0] : null;

                    if (!startField || !word) {
                        return;
                    }

                    const {row, col, vertical} = fieldToCoords(startField);

                    for (let i = 0; i < word.length; i++) {
                        const rune = word[i];
                        if (rune === '.') {
                            continue;
                        }

                        const r = vertical ? row + i : row;
                        const c = vertical ? col : col + i;

                        if (r < 0 || r >= SIZE || c < 0 || c >= SIZE) {
                            continue;
                        }

                        this.board[r][c] = null;
                    }
                },

                buildInitials(name) {
                    const parts = String(name ?? '')
                        .trim()
                        .split(/\s+/)
                        .filter(Boolean);

                    if (parts.length === 0) {
                        return '?';
                    }

                    if (parts.length === 1) {
                        return parts[0].slice(0, 2).toUpperCase();
                    }

                    return `${parts[0][0] ?? ''}${parts[1][0] ?? ''}`.toUpperCase();
                },

                playerInitialsForEvent(event) {
                    const player1Nick = this.parsedPlayers[0]?.nick ?? null;
                    const player2Nick = this.parsedPlayers[1]?.nick ?? null;

                    if (event?.playerNick === player1Nick) {
                        return this.buildInitials(this.details?.player1Name);
                    }

                    if (event?.playerNick === player2Nick) {
                        return this.buildInitials(this.details?.player2Name);
                    }

                    return '?';
                },

                formatExchangeLabel(exchanged) {
                    const value = String(exchanged ?? '').trim();

                    if (value === '') {
                        return 'Wym.';
                    }

                    return `Wym. (${value})`;

                },

                eventLabel(event) {
                    if (event.type === 'p') {
                        const words = event.words ?? [];
                        const move = (words[0] ?? '').trim();

                        if (move === '') {
                            return 'Ruch';
                        }

                        return move;
                    }

                    if (event.type === 'x') {
                        return this.formatExchangeLabel(event.exchanged);
                    }

                    if (event.type === 'pass') {
                        return '[pas]';
                    }

                    if (event.type === 'w') {
                        return '[strata]';
                    }

                    if (event.type === 'challenge') {
                        return '[sprawdzenie]';
                    }

                    if (event.type === 'e') {
                        return '[koniec gry]';
                    }

                    return event.type ?? 'Ruch';
                },

                eventField(event) {
                    const field = String(event?.startField ?? '').trim();
                    return field !== '' ? field : '-';
                },

                formatScore(score) {
                    if (typeof score !== 'number') {
                        return '+0';
                    }

                    return score >= 0 ? `+${score}` : `${score}`;
                },

                goStart() {
                    if (this.events.length === 0) {
                        return;
                    }

                    this.selectedMoveIndex = 0;
                },

                goPrev() {
                    if (this.selectedMoveIndex === null) {
                        return;
                    }

                    this.selectedMoveIndex = this.selectedMoveIndex > 0 ? this.selectedMoveIndex - 1 : null;
                },

                goNext() {
                    if (this.events.length === 0) {
                        return;
                    }

                    if (this.selectedMoveIndex === null) {
                        this.selectedMoveIndex = 0;
                        return;
                    }

                    if (this.selectedMoveIndex < this.events.length - 1) {
                        this.selectedMoveIndex++;
                    }
                },

                goEnd() {
                    if (this.events.length === 0) {
                        return;
                    }

                    this.selectedMoveIndex = this.events.length - 1;
                },

                async fetchDetails() {
                    this.loading = true;
                    this.errorMessage = '';

                    try {
                        const response = await fetch(`/api/games/${this.gameId}`);

                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać szczegółów zapisu gry.');
                        }

                        this.details = await response.json();
                        this.selectedMoveIndex = this.events.length > 0 ? this.events.length - 1 : null;
                        this.renderBoardUntil(this.selectedMoveIndex);
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.details = null;
                        this.errorMessage = error instanceof Error ? error.message : 'Wystąpił nieoczekiwany błąd.';
                    } finally {
                        this.loading = false;
                    }
                },
            };
        }
    </script>
{% endblock %}
