{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'games_over_400' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .games-over-400-player-cell {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }

        .games-over-400-mobile-row {
            display: none;
            font-size: 0.8rem;
            color: #7a7a7a;
            line-height: 1.2;
        }

        @media screen and (max-width: 768px) {
            .games-over-400-table th:nth-child(n+3),
            .games-over-400-table td:nth-child(n+3) {
                display: none;
            }

            .games-over-400-mobile-row {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 0.25rem;
                padding-top: 0.35rem;
                border-top: 1px solid #e5e5e5;
            }

            .games-over-400-mobile-row > span {
                text-align: center;
            }

            .games-over-400-mobile-row > span + span {
                border-left: 1px solid #e5e5e5;
            }
        }
    </style>
{% endblock %}

{% block stats_content %}
    <div x-data="gamesOver400Data()" x-init="fetchRows()">
        <h1 class="title is-3">Gry powyżej 400 pkt</h1>

        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            <div class="control mb-5">
                <input class="input" type="search" placeholder="Filtruj" @input="setSearch($event.target.value)">
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div style="overflow-x: auto;">
                <table class="table is-bordered is-hoverable is-fullwidth games-over-400-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')" style="cursor: pointer;">#</th>
                        <th @click="sort('playerName')" style="cursor: pointer;">Zawodnik</th>
                        <th class="has-text-centered" @click="sort('gamesOver400')" style="cursor: pointer;">Wszystkie gry</th>
                        <th class="has-text-centered" @click="sort('gamesOver400Percent')" style="cursor: pointer;">%</th>
                        <th class="has-text-centered" @click="sort('gamesOver40024Months')" style="cursor: pointer;">Ost 24 mies</th>
                        <th class="has-text-centered" @click="sort('gamesOver40024MonthsPercent')" style="cursor: pointer;">%</th>
                        <th class="has-text-centered" @click="sort('gamesOver40012Months')" style="cursor: pointer;">Ost 12 mies</th>
                        <th class="has-text-centered" @click="sort('gamesOver40012MonthsPercent')" style="cursor: pointer;">%</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="row.playerId">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td>
                                <div class="games-over-400-player-cell">
                                    <a :href="`/players/${row.playerId}`" x-text="row.playerName"></a>
                                    <div class="games-over-400-mobile-row">
                                        <span x-text="formatPlain(row.gamesOver400)"></span>
                                        <span x-text="formatPlain(row.gamesOver40024Months)"></span>
                                        <span x-text="formatPlain(row.gamesOver40012Months)"></span>
                                    </div>
                                    <div class="games-over-400-mobile-row">
                                        <span x-text="formatPercent(row.gamesOver400Percent)"></span>
                                        <span x-text="formatPercent(row.gamesOver40024MonthsPercent)"></span>
                                        <span x-text="formatPercent(row.gamesOver40012MonthsPercent)"></span>
                                    </div>
                                </div>
                            </td>
                            <td class="has-text-centered" x-text="formatPlain(row.gamesOver400)"></td>
                            <td class="has-text-centered" x-text="formatPercent(row.gamesOver400Percent)"></td>
                            <td class="has-text-centered" x-text="formatPlain(row.gamesOver40024Months)"></td>
                            <td class="has-text-centered" x-text="formatPercent(row.gamesOver40024MonthsPercent)"></td>
                            <td class="has-text-centered" x-text="formatPlain(row.gamesOver40012Months)"></td>
                            <td class="has-text-centered" x-text="formatPercent(row.gamesOver40012MonthsPercent)"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function gamesOver400Data() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                sortCol: 'gamesOver40024MonthsPercent',
                sortAsc: true,
                async fetchRows() {
                    try {
                        let response = await fetch('/api/stats/games-over-400');
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać danych o grach powyżej 400 pkt');
                        }

                        let data = await response.json();
                        this.rows = data.rows;
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.rows.sort((a, b) => {
                        if (a[this.sortCol] < b[this.sortCol]) return this.sortAsc ? 1 : -1;
                        if (a[this.sortCol] > b[this.sortCol]) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                nextPage() {
                    if((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if(this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.playerName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if(this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    } else {
                        return [];
                    }
                },
                formatPlain(value) {
                    if (value === null || value === undefined || value === '') {
                        return '-';
                    }

                    return value;
                },
                formatPercent(value) {
                    if (value === null || value === undefined || value === '') {
                        return '-';
                    }

                    return Number(value).toFixed(2) + '%';
                }
            };
        }
    </script>
{% endblock %}
