{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .ranking-layout {
            margin-top: 2rem;
            width: 100%;
        }

        .ranking-content {
            width: 100%;
            max-width: 1160px;
            margin: 0 auto;
        }

        .ranking-table {
            min-width: 720px;
            width: 100%;
        }

        .ranking-header {
            margin-bottom: 1rem;
        }

        .player-cell {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
        }

        .player-main {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .player-mobile-meta {
            display: none;
            font-size: 0.8rem;
            color: #7a7a7a;
            line-height: 1.2;
        }

        @media screen and (max-width: 768px) {
            .ranking-layout {
                margin-top: 1rem;
            }

            .ranking-header {
                margin-bottom: 0.75rem;
            }

            .ranking-table {
                min-width: 0;
            }

            .ranking-table th:nth-child(n+3),
            .ranking-table td:nth-child(n+3) {
                display: none;
            }

            .player-mobile-meta {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 0.25rem;
                margin-top: 0.35rem;
                padding-top: 0.35rem;
                border-top: 1px solid #e5e5e5;
            }

            .player-mobile-meta > span {
                text-align: center;
            }

            .player-mobile-meta > span + span {
                border-left: 1px solid #e5e5e5;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div x-data="rankingData()" x-init="fetchRanking()" class="ranking-layout">
        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>
        <div x-show="!loading" class="ranking-content">
            <h1 class="title has-text-centered mt-5" x-text="`Ranking Polskiej Federacji Scrabble (stary sposób)`"></h1>
            <h6 class="has-text-centered ranking-header">
                <span>Ostatni turniej: </span>
                <template x-if="lastTournamentId">
                    <a :href="`/tournaments/${lastTournamentId}`" x-text="lastTournamentName"></a>
                </template>
                <template x-if="!lastTournamentId">
                    <span x-text="lastTournamentName"></span>
                </template>
            </h6>
            <div class="control mb-5">
                <input class="input" type="search" placeholder="Filtruj" @input="setSearch($event.target.value)">
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div class="table-responsive">
                <table class="table is-bordered is-hoverable ranking-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')">#</th>
                        <th @click="sort('nameAlph')">Zawodnik</th>
                        <th class="has-text-centered" @click="sort('rank')">Ranking</th>
                        <th class="has-text-centered" @click="sort('numberOfGames')">Gier</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRanking" :key="row.position">
                        <tr>
                            <td class="has-text-centered" x-text="row.position + '.'"></td>
                            <td>
                                <div class="player-cell">
                                    <div class="player-main">
                                        <template x-if="row.photo">
                                            <figure class="image is-32x32">
                                                <img
                                                    x-bind:src="row.photo"
                                                    alt="Zdjecie zawodnika"
                                                    style="border-radius: 9999px; object-fit: cover; border: 1px solid #dbdbdb;"
                                                >
                                            </figure>
                                        </template>
                                        <template x-if="!row.photo">
                                            <div
                                                class="is-flex is-justify-content-center is-align-items-center"
                                                style="width: 32px; height: 32px; border-radius: 9999px; border: 1px solid #dbdbdb; background: #f5f5f5;"
                                                aria-label="Brak zdjecia"
                                            >
                                                <svg viewBox="0 0 24 24" width="18" height="18" fill="#7a7a7a" aria-hidden="true">
                                                    <path d="M12 12c2.76 0 5-2.47 5-5.5S14.76 1 12 1 7 3.47 7 6.5 9.24 12 12 12Zm0 2c-4.42 0-8 2.91-8 6.5V23h16v-2.5c0-3.59-3.58-6.5-8-6.5Z"></path>
                                                </svg>
                                            </div>
                                        </template>
                                        <a :href="`/players/${row.playerId}`" x-text="row.nameShow"></a>
                                    </div>
                                    <div class="player-mobile-meta">
                                        <span x-text="formatMobilePlain(row.rank)"></span>
                                        <span x-text="formatMobilePlain(row.numberOfGames)"></span>
                                    </div>
                                </div>
                            </td>
                            <td class="has-text-centered" x-text="row.rank"></td>
                            <td class="has-text-centered" x-text="row.numberOfGames"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
    <script>
        function rankingData() {
            return {
                search: '',
                sortCol: 'position',
                sortAsc: true,
                pageSize: 50,
                curPage: 1,
                ranking: [],
                lastTournamentName: '',
                lastTournamentId: null,
                loading: true,
                async fetchRanking() {
                    try {
                        let response = await fetch('/api/old-rank');
                        if (!response.ok) {
                            throw new Error('Błąd ładowania danych');
                        }
                        let data = await response.json();
                        this.ranking = data.rows;
                        this.lastTournamentName = data.lastTournamentName ?? '-';
                        this.lastTournamentId = data.lastTournamentId ?? null;
                    } catch (error) {
                        console.error('Błąd:', error);
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.ranking.sort((a, b) => {
                        const aValue = this.toSortableValue(a[this.sortCol]);
                        const bValue = this.toSortableValue(b[this.sortCol]);

                        if (aValue < bValue) return this.sortAsc ? 1 : -1;
                        if (aValue > bValue) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                toSortableValue(value) {
                    if (value === null || value === undefined || value === '') {
                        return Number.NEGATIVE_INFINITY;
                    }

                    return value;
                },
                formatMobilePlain(value) {
                    if (parseInt(value) === 0 || value === null || value === undefined || value === '') {
                        return '-';
                    }

                    return value;
                },
                nextPage() {
                    if((this.curPage * this.pageSize) < this.ranking.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if(this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch (search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRanking() {
                    if (this.search === '') {
                        return this.ranking;
                    }
                    return this.ranking.filter((row, index) => {
                        return row.nameShow.toLowerCase().includes(this.search.toLowerCase());
                    })
                },
                get pagedRanking() {
                    if(this.ranking) {
                        const start = (this.curPage-1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRanking.filter((row, index) => {
                            return index >= start && index < end
                        })
                    } else {
                        return [];
                    }
                }
            };
        }
    </script>
{% endblock %}
