{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/static/clubs.css') }}">
{% endblock %}

{% block body %}
    <div x-data="clubsData()" x-init="fetchClubs()" class="clubs-layout">
        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <div x-show="!loading" class="clubs-content">
            <h1 class="title is-3">Kluby</h1>

            <div class="columns is-multiline">
                <template x-for="club in clubs" :key="club.id">
                    <div class="column is-12-mobile is-6-tablet is-3-desktop">
                        <div class="card club-card">
                            <div class="card-content has-text-centered">
                                <figure class="image is-square club-logo">
                                    <img src="/images/club-placeholder.svg" alt="Logo klubu">
                                </figure>
                                <p class="title is-5 mb-2">
                                    <a :href="`/clubs/${club.id}`" x-text="club.name"></a>
                                </p>
                                <p class="subtitle is-6" x-text="club.city"></p>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </div>
    </div>

    <script>
        function clubsData() {
            return {
                clubs: [],
                loading: true,
                async fetchClubs() {
                    try {
                        const response = await fetch('/api/clubs');
                        if (!response.ok) {
                            throw new Error('Błąd ładowania danych klubów');
                        }

                        const data = await response.json();
                        this.clubs = data.clubs ?? [];
                    } catch (error) {
                        console.error('Błąd:', error);
                    } finally {
                        this.loading = false;
                    }
                },
            };
        }
    </script>
{% endblock %}
