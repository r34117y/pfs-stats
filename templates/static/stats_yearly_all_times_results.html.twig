{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'yearly_all_times_results' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/static/stats_yearly_all_times_results.css') }}">
{% endblock %}

{% block stats_content %}
    <div x-data="yearlyAllTimesResultsData()" x-init="fetchRows()">
        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            <div class="field has-addons mb-4">
                <div class="control">
                    <input class="input" type="number" min="1990" max="2100" x-model="selectedYear" placeholder="Rok">
                </div>
                <div class="control">
                    <button class="button is-link" @click="applyYear()">Pokaż</button>
                </div>
            </div>

            {% embed 'static/stats/_search_bar.html.twig' %}{% endembed %}

            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div style="overflow-x: auto;">
                <table class="table is-bordered is-hoverable is-fullwidth yearly-results-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered">#</th>
                        <th>Zawodnik</th>
                        <th class="has-text-centered">1.</th>
                        <th class="has-text-centered">2.</th>
                        <th class="has-text-centered">3.</th>
                        <th class="has-text-centered">4.</th>
                        <th class="has-text-centered">5.</th>
                        <th class="has-text-centered">6.</th>
                        <th class="has-text-centered">1-3.</th>
                        <th class="has-text-centered">1-6.</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="row.playerId">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td>
                                <div class="yearly-results-player-cell">
                                    <a :href="$store.playerLinks.profile(row.playerId)" x-text="row.playerName"></a>
                                    <div class="yearly-results-player-mobile-row yearly-results-player-mobile-row--places">
                                        <span x-text="row.first"></span>
                                        <span x-text="row.second"></span>
                                        <span x-text="row.third"></span>
                                        <span x-text="row.fourth"></span>
                                        <span x-text="row.fifth"></span>
                                        <span x-text="row.sixth"></span>
                                    </div>
                                    <div class="yearly-results-player-mobile-row yearly-results-player-mobile-row--totals">
                                        <span x-text="row.oneToThree"></span>
                                        <span x-text="row.oneToSix"></span>
                                    </div>
                                </div>
                            </td>
                            <td class="has-text-centered" x-text="row.first"></td>
                            <td class="has-text-centered" x-text="row.second"></td>
                            <td class="has-text-centered" x-text="row.third"></td>
                            <td class="has-text-centered" x-text="row.fourth"></td>
                            <td class="has-text-centered" x-text="row.fifth"></td>
                            <td class="has-text-centered" x-text="row.sixth"></td>
                            <td class="has-text-centered" x-text="row.oneToThree"></td>
                            <td class="has-text-centered" x-text="row.oneToSix"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function yearlyAllTimesResultsData() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                selectedYear: (new Date().getFullYear() - 1).toString(),
                async fetchRows() {
                    try {
                        const year = parseInt(this.selectedYear, 10);
                        const response = await fetch(`/api/stats/yearly-all-times-results?year=${year}`);
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać danych statystyk');
                        }

                        const data = await response.json();
                        this.rows = data.rows ?? [];
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                async applyYear() {
                    this.curPage = 1;
                    this.loading = true;
                    this.error = '';
                    await this.fetchRows();
                },
                nextPage() {
                    if ((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if (this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.playerName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if (this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    }

                    return [];
                }
            };
        }
    </script>
{% endblock %}
