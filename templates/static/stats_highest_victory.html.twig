{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'highest_victory' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/static/stats_highest_victory.css') }}">
{% endblock %}

{% block stats_content %}
    <div x-data="highestVictoryData()" x-init="fetchRows()">
        <h1 class="title is-3">Najwyższe zwycięstwo</h1>

        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            {% embed 'static/stats/_search_bar.html.twig' %}{% endembed %}
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div class="highest-victory-table-wrap">
                <table class="table is-bordered is-hoverable is-fullwidth highest-victory-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')" style="cursor: pointer;">#</th>
                        <th class="has-text-centered" @click="sort('points')" style="cursor: pointer;">Punkty</th>
                        <th @click="sort('playerName')" style="cursor: pointer;">Gracz</th>
                        <th class="has-text-centered" @click="sort('opponentName')" style="cursor: pointer;">Przeciwnik</th>
                        <th class="has-text-centered" @click="sort('score')" style="cursor: pointer;">Wynik</th>
                        <th class="has-text-centered" @click="sort('tournamentName')" style="cursor: pointer;">Turniej</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="`${row.position}-${row.playerId}-${row.opponentId}-${row.score}`">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td class="has-text-centered">
                                <span x-text="row.points"></span>
                                <div class="highest-victory-mobile-meta">
                                    <div><strong>Gracz:</strong> <a :href="$store.playerLinks.profile(row.playerId)" x-text="row.playerName"></a></div>
                                    <div><strong>Przeciwnik:</strong> <a :href="$store.playerLinks.profile(row.opponentId)" x-text="row.opponentName"></a></div>
                                    <div><strong>Wynik:</strong> <span x-text="row.score"></span></div>
                                    <div><strong>Turniej:</strong> <span x-text="row.tournamentName"></span></div>
                                </div>
                            </td>
                            <td><a :href="$store.playerLinks.profile(row.playerId)" x-text="row.playerName"></a></td>
                            <td class="has-text-centered"><a :href="$store.playerLinks.profile(row.opponentId)" x-text="row.opponentName"></a></td>
                            <td class="has-text-centered" x-text="row.score"></td>
                            <td class="has-text-centered" x-text="row.tournamentName"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function highestVictoryData() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                sortCol: 'points',
                sortAsc: true,
                async fetchRows() {
                    try {
                        let response = await fetch('/api/stats/highest-victory');
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać danych o najwyższych zwycięstwach');
                        }

                        let data = await response.json();
                        this.rows = data.rows ?? [];
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.rows.sort((a, b) => {
                        if (a[this.sortCol] < b[this.sortCol]) return this.sortAsc ? 1 : -1;
                        if (a[this.sortCol] > b[this.sortCol]) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                nextPage() {
                    if ((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if (this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.playerName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if (this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    } else {
                        return [];
                    }
                }
            };
        }
    </script>
{% endblock %}
