{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'highest_tournament_rank_record' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .highest-tournament-rank-record-player-cell {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }

        .highest-tournament-rank-record-mobile-meta {
            display: none;
            font-size: 0.8rem;
            color: #7a7a7a;
            line-height: 1.3;
        }

        .highest-tournament-rank-record-mobile-meta div + div {
            margin-top: 0.2rem;
        }

        @media screen and (max-width: 768px) {
            .highest-tournament-rank-record-table th:nth-child(n+3),
            .highest-tournament-rank-record-table td:nth-child(n+3) {
                display: none;
            }

            .highest-tournament-rank-record-mobile-meta {
                display: block;
                padding-top: 0.35rem;
                border-top: 1px solid #e5e5e5;
            }
        }
    </style>
{% endblock %}

{% block stats_content %}
    <div x-data="highestTournamentRankRecordData()" x-init="fetchRows()">
        <h1 class="title is-3">Najwyższy ranking z turnieju</h1>

        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            <div class="control mb-5">
                <input class="input" type="search" placeholder="Filtruj" @input="setSearch($event.target.value)">
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div style="overflow-x: auto;">
                <table class="table is-bordered is-hoverable is-fullwidth highest-tournament-rank-record-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')" style="cursor: pointer;">#</th>
                        <th class="has-text-centered" @click="sort('ranking')" style="cursor: pointer;">Ranking</th>
                        <th @click="sort('playerName')" style="cursor: pointer;">Zawodnik</th>
                        <th class="has-text-centered">Wynik</th>
                        <th class="has-text-centered">Turniej</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="row.playerId">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td class="has-text-centered" x-text="row.ranking.toFixed(2)"></td>
                            <td>
                                <div class="highest-tournament-rank-record-player-cell">
                                    <a :href="`/players/${row.playerId}`" x-text="row.playerName"></a>
                                    <div class="highest-tournament-rank-record-mobile-meta">
                                        <div><strong>Ranking:</strong> <span x-text="row.ranking.toFixed(2)"></span></div>
                                        <div><strong>Wynik:</strong> <span x-text="row.result"></span></div>
                                        <div>
                                            <strong>Turniej:</strong>
                                            <a :href="`/tournaments/${row.tournamentId}`" x-text="row.tournamentName"></a>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="has-text-centered" x-text="row.result"></td>
                            <td class="has-text-centered">
                                <a :href="`/tournaments/${row.tournamentId}`" x-text="row.tournamentName"></a>
                            </td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function highestTournamentRankRecordData() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                sortCol: 'ranking',
                sortAsc: true,
                async fetchRows() {
                    try {
                        let response = await fetch('/api/stats/highest-tournament-rank-record');
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać danych o najwyższym rankingu z turnieju');
                        }

                        let data = await response.json();
                        this.rows = data.rows ?? [];
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.rows.sort((a, b) => {
                        if (a[this.sortCol] < b[this.sortCol]) return this.sortAsc ? 1 : -1;
                        if (a[this.sortCol] > b[this.sortCol]) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                nextPage() {
                    if ((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if (this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.playerName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if (this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    } else {
                        return [];
                    }
                }
            };
        }
    </script>
{% endblock %}
