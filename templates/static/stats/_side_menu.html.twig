<style>
    .stats-side-menu .menu-list a.is-active {
        background-color: #e8f1ff;
        color: #1f3f6f;
        font-weight: 600;
    }

    .stats-side-menu .menu-list a.is-active:hover {
        background-color: #dce9ff;
        color: #1a355d;
    }

    .stats-side-menu-toggle {
        display: none;
    }

    @media screen and (max-width: 768px) {
        .stats-side-menu .menu-label {
            display: none;
        }

        .stats-side-menu-toggle {
            align-items: center;
            background: transparent;
            border: 0;
            color: inherit;
            cursor: pointer;
            display: flex;
            font: inherit;
            font-weight: 600;
            justify-content: space-between;
            padding: 0;
            text-align: left;
            width: 100%;
        }

        .stats-side-menu-toggle::after {
            border: solid currentColor;
            border-width: 0 2px 2px 0;
            content: "";
            height: 0.55rem;
            margin-left: 1rem;
            transform: rotate(45deg);
            transition: transform 120ms ease-in-out;
            width: 0.55rem;
        }

        .stats-side-menu.is-open .stats-side-menu-toggle::after {
            transform: rotate(-135deg);
        }

        .stats-side-menu .menu-list {
            display: none;
            margin-top: 0.75rem;
        }

        .stats-side-menu.is-open .menu-list {
            display: block;
        }
    }
</style>

