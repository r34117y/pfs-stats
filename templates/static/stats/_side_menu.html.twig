<script>
    (() => {
        document.querySelectorAll('.stats-side-menu').forEach((menuElement) => {
            const toggleElement = menuElement.querySelector('.stats-side-menu-toggle');
            if (!toggleElement) {
                return;
            }

            toggleElement.addEventListener('click', () => {
                const isOpen = menuElement.classList.toggle('is-open');
                toggleElement.setAttribute('aria-expanded', String(isOpen));
            });
        });
    })();
</script>
