{% extends 'base.html.twig' %}

{% block body %}
    <div x-data="annotatedGamesData()" x-init="fetchGames()" style="margin-top: 2rem;">
        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <div x-show="!loading" class="box">
            <div class="columns is-multiline mb-2">
                <div class="column is-12-mobile is-6-tablet">
                    <label class="label" for="player-name-filter">Filtruj po zawodniku</label>
                    <input
                        id="player-name-filter"
                        class="input"
                        type="search"
                        placeholder="Wpisz nazwę zawodnika"
                        x-model="playerName"
                        @input="applyFiltersDebounced()"
                    >
                </div>
                <div class="column is-12-mobile is-6-tablet">
                    <label class="label" for="tournament-name-filter">Filtruj po turnieju</label>
                    <input
                        id="tournament-name-filter"
                        class="input"
                        type="search"
                        placeholder="Wpisz nazwę turnieju"
                        x-model="tournamentName"
                        @input="applyFiltersDebounced()"
                    >
                </div>
            </div>

            <div class="is-flex is-justify-content-space-between is-align-items-center mb-3" style="gap: 0.5rem; flex-wrap: wrap;">
                <button class="button" @click="previousPage" :disabled="page <= 1 || loading"><< Poprzednia</button>
                <p class="is-size-7 has-text-grey" x-text="paginationText"></p>
                <button class="button" @click="nextPage" :disabled="page >= totalPages || loading">Następna >></button>
            </div>

            <div class="table-responsive">
                <table class="table is-bordered is-hoverable is-fullwidth">
                    <thead>
                    <tr>
                        <th>Turniej</th>
                        <th class="has-text-centered">Runda</th>
                        <th>Zawodnik 1</th>
                        <th>Zawodnik 2</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-if="games.length === 0">
                        <tr>
                            <td colspan="4" class="has-text-centered">Brak wyników</td>
                        </tr>
                    </template>
                    <template x-for="(game, index) in games" :key="`${game.tournamentName}-${game.round}-${game.player1Name}-${game.player2Name}-${index}`">
                        <tr>
                            <td x-text="game.tournamentName"></td>
                            <td class="has-text-centered" x-text="game.round"></td>
                            <td x-text="game.player1Name"></td>
                            <td x-text="game.player2Name"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>

            <div class="is-flex is-justify-content-space-between is-align-items-center mt-3" style="gap: 0.5rem; flex-wrap: wrap;">
                <button class="button" @click="previousPage" :disabled="page <= 1 || loading"><< Poprzednia</button>
                <p class="is-size-7 has-text-grey" x-text="paginationText"></p>
                <button class="button" @click="nextPage" :disabled="page >= totalPages || loading">Następna >></button>
            </div>
        </div>
    </div>

    <script>
        function annotatedGamesData() {
            return {
                games: [],
                page: 1,
                pageSize: 20,
                totalItems: 0,
                totalPages: 1,
                playerName: '',
                tournamentName: '',
                loading: true,
                debounceTimer: null,

                async fetchGames() {
                    this.loading = true;

                    try {
                        const params = new URLSearchParams({
                            page: this.page.toString(),
                        });

                        if (this.playerName.trim() !== '') {
                            params.set('playerName', this.playerName.trim());
                        }

                        if (this.tournamentName.trim() !== '') {
                            params.set('tournamentName', this.tournamentName.trim());
                        }

                        const response = await fetch(`/api/annotated-games?${params.toString()}`);

                        if (!response.ok) {
                            throw new Error('Błąd ładowania danych');
                        }

                        const data = await response.json();
                        this.games = data.items ?? [];
                        this.page = data.page ?? 1;
                        this.pageSize = data.pageSize ?? 50;
                        this.totalItems = data.totalItems ?? 0;
                        this.totalPages = data.totalPages ?? 1;
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.games = [];
                        this.totalItems = 0;
                        this.totalPages = 1;
                    } finally {
                        this.loading = false;
                    }
                },

                applyFiltersDebounced() {
                    if (this.debounceTimer !== null) {
                        clearTimeout(this.debounceTimer);
                    }

                    this.debounceTimer = setTimeout(() => {
                        this.page = 1;
                        this.fetchGames();
                    }, 300);
                },

                nextPage() {
                    if (this.page >= this.totalPages || this.loading) {
                        return;
                    }

                    this.page++;
                    this.fetchGames();
                },

                previousPage() {
                    if (this.page <= 1 || this.loading) {
                        return;
                    }

                    this.page--;
                    this.fetchGames();
                },

                get paginationText() {
                    if (this.totalItems <= 0) {
                        return 'Brak wyników';
                    }

                    const from = ((this.page - 1) * this.pageSize) + 1;
                    const to = Math.min(this.page * this.pageSize, this.totalItems);

                    return `Strona ${this.page}/${this.totalPages} • ${from}-${to} z ${this.totalItems}`;
                },
            };
        }
    </script>
{% endblock %}
