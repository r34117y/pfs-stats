{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'longest_win_streak_vs_player' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/static/stats_longest_win_streak_vs_player.css') }}">
{% endblock %}

{% block stats_content %}
    <div x-data="longestWinStreakVsPlayerData()" x-init="fetchRows()">
        <h1 class="title is-3">Najdłuższa seria zwycięstw z graczem</h1>

        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            <div class="control mb-5">
                <input class="input" type="search" placeholder="Filtruj" @input="setSearch($event.target.value)">
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div style="overflow-x: auto;">
                <table class="table is-bordered is-hoverable is-fullwidth longest-win-streak-vs-player-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')" style="cursor: pointer;">#</th>
                        <th @click="sort('winnerName')" style="cursor: pointer;">Zwycięzca</th>
                        <th @click="sort('opponentName')" style="cursor: pointer;">Przeciwnik</th>
                        <th class="has-text-centered" @click="sort('winsStreak')" style="cursor: pointer;">Zwycięstw</th>
                        <th class="has-text-centered">Pierwszy i ostatni Turniej</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="`${row.winnerId}-${row.opponentId}`">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td>
                                <div class="longest-win-streak-vs-player-winner-cell">
                                    <a :href="$store.playerLinks.profile(row.winnerId)" x-text="row.winnerName"></a>
                                    <div class="longest-win-streak-vs-player-mobile-meta">
                                        <div><strong>Przeciwnik:</strong> <a :href="$store.playerLinks.profile(row.opponentId)" x-text="row.opponentName"></a></div>
                                        <div><strong>Zwycięstw:</strong> <span x-text="row.winsStreak"></span></div>
                                        <div>
                                            <strong>Pierwszy i ostatni turniej:</strong>
                                            <a :href="`/tournaments/${row.firstTournamentId}`" x-text="row.firstTournamentName"></a>
                                            <span> - </span>
                                            <a :href="`/tournaments/${row.lastTournamentId}`" x-text="row.lastTournamentName"></a>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a :href="$store.playerLinks.profile(row.opponentId)" x-text="row.opponentName"></a>
                            </td>
                            <td class="has-text-centered" x-text="row.winsStreak"></td>
                            <td class="has-text-centered">
                                <a :href="`/tournaments/${row.firstTournamentId}`" x-text="row.firstTournamentName"></a>
                                <span> - </span>
                                <a :href="`/tournaments/${row.lastTournamentId}`" x-text="row.lastTournamentName"></a>
                            </td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function longestWinStreakVsPlayerData() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                sortCol: 'winsStreak',
                sortAsc: true,
                async fetchRows() {
                    try {
                        let response = await fetch('/api/stats/longest-win-streak-vs-player');
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać danych o najdłuższej serii zwycięstw z graczem');
                        }

                        let data = await response.json();
                        this.rows = data.rows ?? [];
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.rows.sort((a, b) => {
                        if (a[this.sortCol] < b[this.sortCol]) return this.sortAsc ? 1 : -1;
                        if (a[this.sortCol] > b[this.sortCol]) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                nextPage() {
                    if ((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if (this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.winnerName ?? '').toLowerCase().includes(normalizedSearch)
                            || (row.opponentName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if (this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    } else {
                        return [];
                    }
                }
            };
        }
    </script>
{% endblock %}
