{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'ranking_leaders' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/static/stats_ranking_leaders.css') }}">
{% endblock %}

{% block stats_content %}
    <div x-data="rankingLeadersData()" x-init="fetchRows()">
        <h1 class="title is-3">Liderzy rankingu</h1>

        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            {% embed 'static/stats/_search_bar.html.twig' %}{% endembed %}
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div style="overflow-x: auto;">
                <table class="table is-bordered is-hoverable is-fullwidth ranking-leaders-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')" style="cursor: pointer;">#</th>
                        <th @click="sort('playerName')" style="cursor: pointer;">Zawodnik</th>
                        <th class="has-text-centered" @click="sort('daysOnTop')" style="cursor: pointer;">Dni na czele</th>
                        <th class="has-text-centered" @click="sort('firstAndLastTournament')" style="cursor: pointer;">Pierwszy i ostatni turniej</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="`${row.playerId}-${row.position}`">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td>
                                <div class="ranking-leaders-player-cell">
                                    <a :href="$store.playerLinks.profile(row.playerId)" x-text="row.playerName"></a>
                                    <div class="ranking-leaders-mobile-meta">
                                        <span x-text="row.daysOnTop"></span>
                                        <span x-text="formatTournamentSpan(row)"></span>
                                    </div>
                                </div>
                            </td>
                            <td class="has-text-centered" x-text="row.daysOnTop"></td>
                            <td class="has-text-centered" x-text="formatTournamentSpan(row)"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function rankingLeadersData() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                sortCol: 'daysOnTop',
                sortAsc: true,
                async fetchRows() {
                    try {
                        let response = await fetch('/api/stats/ranking-leaders');
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać liderów rankingu');
                        }

                        let data = await response.json();
                        this.rows = (data.rows ?? []).map((row) => {
                            return {
                                ...row,
                                firstAndLastTournament: this.formatTournamentSpan(row),
                            };
                        });
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.rows.sort((a, b) => {
                        if (a[this.sortCol] < b[this.sortCol]) return this.sortAsc ? 1 : -1;
                        if (a[this.sortCol] > b[this.sortCol]) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                nextPage() {
                    if((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if(this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.playerName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if(this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    } else {
                        return [];
                    }
                },
                formatTournamentSpan(row) {
                    const first = row.firstTournamentName ?? '-';
                    const last = row.lastTournamentName ?? '-';
                    if (first === last) {
                        return first;
                    }

                    return `${first} - ${last}`;
                }
            };
        }
    </script>
{% endblock %}
