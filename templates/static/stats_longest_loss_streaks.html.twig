{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = 'longest_loss_streaks' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/static/stats_longest_loss_streaks.css') }}">
{% endblock %}

{% block stats_content %}
    <div x-data="longestLossStreaksData()" x-init="fetchRows()">
        <h1 class="title is-3">Najdłuższa seria porażek</h1>

        <template x-if="loading">
            <p>Ładowanie...</p>
        </template>

        <template x-if="error">
            <article class="message is-danger">
                <div class="message-body" x-text="error"></div>
            </article>
        </template>

        <div x-show="!loading && !error">
            {% embed 'static/stats/_search_bar.html.twig' %}{% endembed %}
            {% include 'static/_partials/_pagination.html.twig' with {position: 'top'} %}
            <div style="overflow-x: auto;">
                <table class="table is-bordered is-hoverable is-fullwidth longest-loss-streaks-table">
                    <thead>
                    <tr>
                        <th class="has-text-centered" @click="sort('position')" style="cursor: pointer;">#</th>
                        <th @click="sort('playerName')" style="cursor: pointer;">Zawodnik</th>
                        <th class="has-text-centered" @click="sort('lossesStreak')" style="cursor: pointer;">Porażek</th>
                        <th class="has-text-centered">Turnieje</th>
                        <th class="has-text-centered" @click="sort('currentStreak')" style="cursor: pointer;">Aktualna passa</th>
                    </tr>
                    </thead>
                    <tbody>
                    <template x-for="row in pagedRows" :key="row.playerId">
                        <tr>
                            <td class="has-text-centered" x-text="`${row.position}.`"></td>
                            <td>
                                <div class="longest-loss-streaks-player-cell">
                                    <a :href="$store.playerLinks.profile(row.playerId)" x-text="row.playerName"></a>
                                    <div class="longest-loss-streaks-mobile-meta">
                                        <div><strong>Porażek:</strong> <span x-text="row.lossesStreak"></span></div>
                                        <div>
                                            <strong>Turnieje:</strong>
                                            <span class="longest-loss-streaks-tournaments">
                                                <template x-for="tournament in row.tournaments" :key="tournament.id">
                                                    <a :href="`/tournaments/${tournament.id}`" x-text="tournament.name"></a>
                                                </template>
                                            </span>
                                        </div>
                                        <div><strong>Aktualna passa:</strong> <span x-text="row.currentStreak"></span></div>
                                    </div>
                                </div>
                            </td>
                            <td class="has-text-centered" x-text="row.lossesStreak"></td>
                            <td class="has-text-centered">
                                <span class="longest-loss-streaks-tournaments">
                                    <template x-for="tournament in row.tournaments" :key="tournament.id">
                                        <a :href="`/tournaments/${tournament.id}`" x-text="tournament.name"></a>
                                    </template>
                                </span>
                            </td>
                            <td class="has-text-centered" x-text="row.currentStreak"></td>
                        </tr>
                    </template>
                    </tbody>
                </table>
            </div>
            {% include 'static/_partials/_pagination.html.twig' with {position: 'bottom'} %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function longestLossStreaksData() {
            return {
                loading: true,
                error: '',
                search: '',
                pageSize: 100,
                curPage: 1,
                rows: [],
                sortCol: 'lossesStreak',
                sortAsc: false,
                async fetchRows() {
                    try {
                        let response = await fetch('/api/stats/longest-loss-streaks');
                        if (!response.ok) {
                            throw new Error('Nie udało się pobrać danych o seriach porażek');
                        }

                        let data = await response.json();
                        this.rows = data.rows ?? [];
                    } catch (error) {
                        console.error('Błąd:', error);
                        this.error = error.message;
                    } finally {
                        this.loading = false;
                    }
                },
                sort(col) {
                    if (this.sortCol === col) this.sortAsc = !this.sortAsc;
                    this.sortCol = col;
                    this.rows.sort((a, b) => {
                        if (a[this.sortCol] < b[this.sortCol]) return this.sortAsc ? 1 : -1;
                        if (a[this.sortCol] > b[this.sortCol]) return this.sortAsc ? -1 : 1;
                        return 0;
                    });
                },
                nextPage() {
                    if ((this.curPage * this.pageSize) < this.filteredRows.length) {
                        this.curPage++;
                    }
                },
                previousPage() {
                    if (this.curPage > 1) {
                        this.curPage--;
                    }
                },
                setSearch(search) {
                    this.curPage = 1;
                    this.search = search;
                },
                get filteredRows() {
                    if (this.search === '') {
                        return this.rows;
                    }

                    const normalizedSearch = this.search.toLowerCase();
                    return this.rows.filter((row) => {
                        return (row.playerName ?? '').toLowerCase().includes(normalizedSearch);
                    });
                },
                get pagedRows() {
                    if (this.rows) {
                        const start = (this.curPage - 1) * this.pageSize;
                        const end = this.curPage * this.pageSize;
                        return this.filteredRows.filter((row, index) => {
                            return index >= start && index < end;
                        });
                    } else {
                        return [];
                    }
                }
            };
        }
    </script>
{% endblock %}
