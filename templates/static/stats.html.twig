{% extends 'static/stats/_base_stats.html.twig' %}

{% set activeStatsItem = null %}

{% block stats_content %}
    <section>
        <h1 class="title is-3">Statystyki</h1>
        <div class="columns is-multiline">
            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="/stats/all-times-results" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M7 2h10v3h3v17H4V5h3V2Zm2 3h6V4H9v1Zm-2 3v2h10V8H7Zm0 4v2h10v-2H7Zm0 4v2h7v-2H7Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Miejsca w turniejach</p>
                        <p class="subtitle is-6">Sprawdź, jak zawodnicy plasowali się w historii turniejów.</p>
                    </div>
                </a>
            </div>

            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="/stats/all-time-summary" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M3 20h18v2H3v-2Zm2-2V9h3v9H5Zm5 0V5h3v13h-3Zm5 0v-7h3v7h-3Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Podsumowanie</p>
                        <p class="subtitle is-6">Zobacz ogólny obraz osiągnięć i aktywności zawodników.</p>
                    </div>
                </a>
            </div>

            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="/stats/games" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M4 4h16v16H4V4Zm2 2v5h5V6H6Zm7 0v5h5V6h-5ZM6 13v5h5v-5H6Zm7 5h5v-5h-5v5Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Liczba gier</p>
                        <p class="subtitle is-6">Porównaj, ilu gier rozegrali poszczególni zawodnicy.</p>
                    </div>
                </a>
            </div>

            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="/stats/games-won" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M7 2h10v3h3v3c0 3.31-2.69 6-6 6h-1v3h4v2H7v-2h4v-3h-1c-3.31 0-6-2.69-6-6V5h3V2Zm-1 5v1c0 2.21 1.79 4 4 4h4c2.21 0 4-1.79 4-4V7H6Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Wygrane gry</p>
                        <p class="subtitle is-6">Sprawdź, którzy gracze najczęściej kończą partie zwycięstwem.</p>
                    </div>
                </a>
            </div>

            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="/stats/tournaments" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M12 2 2 7l10 5 10-5-10-5Zm-8 9 8 4 8-4v6l-8 5-8-5v-6Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Liczba turniejów</p>
                        <p class="subtitle is-6">Zestaw udział zawodników w turniejach i ich aktywność sezonową.</p>
                    </div>
                </a>
            </div>

            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="/stats/avg-points-per-game" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M3 21h18v2H3v-2Zm2-3 4-5 3 3 5-7 2 1-6 8-3-3-3 4-2-1Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Średnia punktów</p>
                        <p class="subtitle is-6">Porównaj średnią punktację na grę między zawodnikami.</p>
                    </div>
                </a>
            </div>

            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="#" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M4 4h16v4H4V4Zm0 6h7v10H4V10Zm9 0h7v4h-7v-4Zm0 6h7v4h-7v-4Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Zestawienia</p>
                        <p class="subtitle is-6">Przeglądaj przekrojowe raporty łączące wiele typów statystyk.</p>
                    </div>
                </a>
            </div>

            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="#" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M7 2h2v3H7V2Zm8 0h2v3h-2V2ZM4 6h16v14H4V6Zm2 4v8h12v-8H6Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Podsumowania lat</p>
                        <p class="subtitle is-6">Analizuj wyniki i trendy sezon po sezonie w ujęciu rocznym.</p>
                    </div>
                </a>
            </div>

            <div class="column is-12-mobile is-6-tablet is-3-desktop">
                <a href="#" class="card is-block">
                    <div class="card-content">
                        <span class="icon is-large mb-2">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
                                <path d="M4 4h16v12H5.17L4 17.17V4Zm2 2v7.17L6.83 12H18V6H6Zm0 13h14v2H6v-2Z"></path>
                            </svg>
                        </span>
                        <p class="title is-5 mb-2">Zapisy gier</p>
                        <p class="subtitle is-6">Odszukaj szczegółowe zapisy partii i przebieg pojedynków.</p>
                    </div>
                </a>
            </div>
        </div>
    </section>
{% endblock %}
